{
  "name": "jm_custom_theme",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "generate:tokens": "node scripts/generate-tokens.mjs",
    "build:assets": "rsync -av --delete src/assets/ build/assets/",
    "build:styles": "sass src/scss/style.scss:build/css/style.css src/scss/editor-style.scss:build/css/editor-style.css --load-path=src/scss --no-source-map --style=compressed",
    "build:js": "wp-scripts build --output-path=build/js",
    "build": "npm run generate:tokens && npm run build:assets && npm run build:styles && npm run build:js",
    "start": "concurrently \"wp-scripts start --output-path=build/js\" \"sass --watch src/scss/style.scss:build/css/style.css src/scss/editor-style.scss:build/css/editor-style.css --load-path=src/scss\"",
    "package": "npm run build && rm -rf dist && mkdir -p dist && rsync -av --delete build/ dist/ && rsync -av theme.json style.css functions.php dist/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/John-McPherson/amc_electrical.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/John-McPherson/amc_electrical/issues"
  },
  "homepage": "https://github.com/John-McPherson/jm_custom_theme#readme",
  "devDependencies": {
    "@wordpress/block-editor": "^15.22.0",
    "@wordpress/blocks": "^15.22.0",
    "@wordpress/element": "^8.1.0",
    "@wordpress/i18n": "^6.22.0",
    "@wordpress/scripts": "^32.4.0",
    "concurrently": "^10.0.3",
    "sass": "^1.101.0"
  }
}
